# OpenAI / LLM
OPENAI_API_KEY=sk-your-openai-key
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.3

# Deepgram STT
DEEPGRAM_API_KEY=your-deepgram-key
STT_MODEL=nova-3
STT_LANGUAGE=multi

# Sarvam TTS
SARVAM_API_KEY=sk-your-sarvam-key
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=priya
SARVAM_TTS_LANGUAGE=auto
SARVAM_TTS_SAMPLE_RATE=24000
SARVAM_TTS_PACE=0.92
SARVAM_TTS_TEMPERATURE=0.6

# ElevenLabs TTS (fallback)
ELEVENLABS_API_KEY=sk-your-elevenlabs-key

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Spatius (avatar)
SPATIUS_APP_ID=your-spatius-app-id
SPATIUS_API_KEY=sk-your-spatius-key
SPATIUS_AVATAR_ID=your-avatar-uuid
SPATIUS_REGION=us-west

# Database (Supabase Postgres)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Redis (Upstash)
REDIS_URL=rediss://default:password@host:6379
REDIS_STREAM_NAME=pratham:intake_events
REDIS_CONSUMER_GROUP=arogyam_consumers

# Application
HOSPITAL_ID=default
MAX_RETRIES_PER_FIELD=2
SESSION_TIMEOUT_SECONDS=900
EMERGENCY_KEYWORDS_PATH=agent/config/emergency_keywords.txt

# Google (E2E voice model)
GOOGLE_API_KEY=AIza-your-google-key
E2E_GOOGLE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
E2E_GOOGLE_VOICE=Puck

# JWT
JWT_SECRET_KEY=generate-a-random-secret
